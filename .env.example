# Database (DB_HOST, DB_PORT, DB_USER, DB_NAME, DB_SSLMODE are set in docker-compose.yml)
DB_PASSWORD=changeme

# Authentication
JWT_SECRET=run_openssl_rand_hex_32_to_generate

# HTTPS (optional): set both to enable TLS
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# Nokia OLT SSH credentials
OLT_SSH_USER=
OLT_SSH_PASS=

# Huawei OLT SSH credentials (falls back to Nokia credentials if not set)
HW_SSH_USER=
HW_SSH_PASS=

# NOC Data auto-detection credentials
NOC_DATA_CISCO_USER=
NOC_DATA_CISCO_PASS=
NOC_DATA_MIKROTIK_USER=
NOC_DATA_MIKROTIK_PASS=
# NOC Data stability tuning
# Lower workers = slower scans but fewer concurrency-related device issues
# NOC_DATA_WORKERS=3
# Sleep after most NOC data commands
# NOC_DATA_CMD_GAP=250ms
# Longer sleep after heavier commands like display elabel/current-configuration
# NOC_DATA_HEAVY_CMD_GAP=750ms

# NOC Data debug tracing
# Set to false to stop writing backups/logs/noc-data/noc-data-debug.log
# NOC_DATA_LOG_ENABLED=true
# Optional: comma-separated IPs to trace in detail
# NOC_DATA_TRACE_HOSTS=

# OLTs API endpoint
OLTS_API_ENV=

# HTTPS (optional - leave empty for HTTP only)
# Generate cert: openssl req -x509 -newkey rsa:4096 -keyout certs/server.key -out certs/server.crt -days 365 -nodes -subj "/CN=10.80.6.22" -addext "subjectAltName=IP:10.80.6.22,IP:127.0.0.1"
# TLS_CERT=/app/certs/server.crt
# TLS_KEY=/app/certs/server.key

# Scan intervals (optional, defaults shown)
# POWER_SCAN_INTERVAL=6h
# HEALTH_SCAN_INTERVAL=0.5h
# DESC_SCAN_INTERVAL=6h
# PORT_SCAN_INTERVAL=0.5h
# BACKUP_INTERVAL=24h

# ── Huawei ONT power scan tuning ──
# HW_POWER_SLOTS=all            # Scan all GPON slots (1–15, or 0–15 for Hafriya). Or e.g. "1,2"
# HW_POWER_PONS=                # Empty = all 16 PONs. Or e.g. "0,1,2" to limit
# HW_POWER_ONT_CHUNK=128        # ONTs per CLI command (1–128). Higher = fewer commands.
# HW_POWER_ONT_MIN=0            # Start ONT ID (default 0)
# HW_POWER_ONT_MAX=127          # End ONT ID inclusive (default 127)
# HW_SSH_CMD_TIMEOUT_SEC=30     # Per-command prompt timeout (5–7200, default 30)
# HW_SSH_RECOVERY_TIMEOUT_SEC=10 # Post-timeout resync timeout (5–300, default 10)
# HW_OPTICAL_SLEEP_MS=4         # Post-command delay for optical-info (default 4ms)
# HW_OPTICAL_GAP_MS=2           # Pre-command delay for optical-info (default 2ms)

# ── Slack: syslog alerts (optional) ──
# SLACK_SYSLOG_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789
# SLACK_SIGNING_SECRET=...   # App → Basic Information → Signing Secret (Events API)
# SLACK_REMINDER_INTERVAL=6h
# SLACK_SYSLOG_BATCH_WINDOW=45s
# SLACK_SYSLOG_DISPLAY_OFFSET=3h
# SLACK_SYSLOG_TEAM_MENTION=<!subteam^S01234567|ip-core>
# (Get subteam ID from Slack: User groups → ip-core → copy; plain @ip-core in text does not notify the group.)
# Public HTTPS URL required: POST https://your-host/api/slack/events
# Bot scopes: chat:write, channels:history, users:read, reactions:read
# Event Subscriptions: message.channels, reaction_added (and message.groups for private channels)

# -- Ruijie Cloud alarm mail -> Slack (optional) --
# Reads Microsoft 365/Outlook Junk Email through Microsoft Graph every minute.
# Requires an Azure app with application permission Mail.Read and admin consent.
# Uses the same SLACK_BOT_TOKEN and optional SLACK_SIGNING_SECRET reaction flow.
# RUIJIE_MAIL_ENABLED=true
# RUIJIE_MAIL_TENANT_ID=00000000-0000-0000-0000-000000000000
# RUIJIE_MAIL_CLIENT_ID=00000000-0000-0000-0000-000000000000
# RUIJIE_MAIL_CLIENT_SECRET=...
# RUIJIE_MAIL_USER_ID=hussein.kifah@fiberx.iq
# RUIJIE_MAIL_FOLDER_ID=junkemail
# RUIJIE_MAIL_SUBJECT=Ruijie Cloud Alarm Notification
# RUIJIE_MAIL_POLL_INTERVAL=1m
# RUIJIE_MAIL_LOOKBACK=10m
# RUIJIE_SLACK_CHANNEL_ID=C0123456789
# RUIJIE_SLACK_TEAM_MENTION=<!subteam^S01234567|ip-team>
# RUIJIE_SLACK_REMINDER_INTERVAL=6h
# RUIJIE_SLACK_DISPLAY_OFFSET=3h
#
# One-time reset of Slack incident state (run in psql when you need a clean slate):
#   UPDATE es_syslog_alerts SET slack_incident_id = NULL WHERE slack_incident_id IS NOT NULL;
#   DELETE FROM es_syslog_slack_incidents;

# ── Slack: ticket thread reminders (optional) ──
# Tracks new top-level ticket messages in one channel, reminds every 6h,
# tags the IP team when there are no replies, and stops on :white_check_mark:.
# Uses the same Slack app token + signing secret and the same /api/slack/events endpoint.
# SLACK_TICKET_REMINDER_ENABLED=true
# SLACK_TICKET_CHANNEL_ID=C0123456789
# SLACK_TICKET_REMINDER_INTERVAL=6h
# SLACK_TICKET_FIRST_REMINDER_AFTER=6h
# SLACK_TICKET_TICK_INTERVAL=2m
# SLACK_TICKET_IP_TEAM_MENTION=<!subteam^S01234567|ip-team>
# SLACK_TICKET_DISPLAY_OFFSET=3h
# SLACK_TICKET_SOURCE_BOT_ID=B0123456789   # optional: only track ticket messages from this bot
# Extra Slack requirements for ticket reminders:
# Bot scopes: chat:write, channels:history, reactions:read, users:read
# Event Subscriptions: message.channels, reaction_added (and message.groups for private channels)

# ── Slack: IP Activity Log daily summary (optional) ──
# Sends one daily message with backup/activity-log errors, or an all-clear summary.
# Uses SLACK_BOT_TOKEN.
# SLACK_ACTIVITY_LOG_ENABLED=true
# SLACK_ACTIVITY_LOG_CHANNEL_ID=C0B063ARXPX
# SLACK_ACTIVITY_LOG_DAILY_TIME=09:00
# SLACK_ACTIVITY_LOG_DISPLAY_OFFSET=3h
