# Database (DB_HOST, DB_PORT, DB_USER, DB_NAME, DB_SSLMODE are set in docker-compose.yml)
DB_PASSWORD=changeme

# Authentication
JWT_SECRET=run_openssl_rand_hex_32_to_generate

# HTTPS (optional): set both to enable TLS
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# Nokia OLT SSH credentials
OLT_SSH_USER=
OLT_SSH_PASS=

# Huawei OLT SSH credentials (falls back to Nokia credentials if not set)
HW_SSH_USER=
HW_SSH_PASS=

# OLTs API endpoint
OLTS_API_ENV=

# Huawei power collection (optional)
# HW_POWER_SLEEP_MS=80        # After each cmd (prompt seen), ms — raise if OLT drops/skips lines (default 80)
# HW_POWER_CMD_GAP_MS=12      # Pause before sending each cmd, ms — set 0-30 to tune (default 12)
# HW_POWER_ONT_CHUNK=64       # ONTs per batch (1-128)
# HW_POWER_ONT_MAX=128        # Max ONT index per PON (1-128)
# HW_POWER_SLOTS=1            # "1", "0,1", or "all" for 0-15
# HW_POWER_PONS=0,1,2,3       # PONs to scan, or omit for all 0-7

# Scan intervals (optional, defaults shown)
# POWER_SCAN_INTERVAL=6h
# HEALTH_SCAN_INTERVAL=0.5h
# DESC_SCAN_INTERVAL=6h
# PORT_SCAN_INTERVAL=0.5h
# BACKUP_INTERVAL=24h
